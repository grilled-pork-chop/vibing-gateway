{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Usage by user",
  "uid": "llm-usage-by-user",
  "tags": ["llm", "usage", "per-user"],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "description": "Best-effort attribution by the X-User identity header recorded at agentgateway. The header is client-supplied and spoofable — this is for visibility, not authentication or billing. See TELEMETRY.md.",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "user",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(agentgateway_requests_total, user)",
        "query": { "query": "label_values(agentgateway_requests_total, user)", "refId": "user" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "Attribution is by the **X-User** request header recorded at agentgateway (best-effort, spoofable — not auth). The exact metric/label name (`agentgateway_requests_total{user=...}`) depends on the gateway's metrics config; if only access logs carry tokens, replace these panels with a logs/LogQL source. See **TELEMETRY.md → Per-user attribution**." }
    },
    {
      "type": "timeseries",
      "title": "Requests/sec by user",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 3 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (user) (rate(agentgateway_requests_total{user=~\"$user\"}[5m]))", "legendFormat": "{{user}}" }
      ]
    },
    {
      "type": "table",
      "title": "Total requests by user (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 3 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "format": "table", "instant": true, "expr": "sum by (user) (increase(agentgateway_requests_total{user=~\"$user\"}[$__range]))" }
      ]
    }
  ]
}
